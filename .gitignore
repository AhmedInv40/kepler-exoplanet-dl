# ============================================================================
# Data files — never commit raw datasets or processed splits
# ============================================================================
data/raw/*
data/processed/*
data/interim/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/interim/.gitkeep
*.csv
*.parquet
*.feather
*.h5
*.hdf5

# ============================================================================
# Trained models — too large for git
# ============================================================================
models/*
!models/.gitkeep
*.pt
*.pth
*.pkl
*.joblib
*.onnx

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# ============================================================================
# Virtual environments
# ============================================================================
venv/
.venv/
env/
.env/
ENV/

# ============================================================================
# Jupyter Notebook
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ============================================================================
# Environment variables and secrets
# ============================================================================
.env
.env.local
*.key
*.pem
secrets/

# ============================================================================
# MLflow tracking
# ============================================================================
mlruns/
mlartifacts/

# ============================================================================
# IDE and editors
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================================
# Logs and temporary files
# ============================================================================
*.log
logs/
tmp/
temp/

# ============================================================================
# Reports — keep figures folder structure but ignore generated PDFs
# ============================================================================
reports/*.pdf
!reports/figures/.gitkeep

# ============================================================================
# OS-specific
# ============================================================================
Thumbs.db
Desktop.ini
